# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed as the template.

# --- Database (Supabase Postgres) ---------------------------------------
# Pooled connection string (port 6543, pgBouncer). Used by the app at
# runtime via Prisma Client. Append ?pgbouncer=true&connection_limit=1
# when using the pooled URL with Prisma.
DATABASE_URL=

# Direct connection string (port 5432). Used by Prisma Migrate / introspect
# because pgBouncer (transaction mode) cannot run migration statements.
DIRECT_URL=

# --- Authentication (Clerk) --------------------------------------------
# Publishable key — safe to expose in the browser bundle.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Secret key — server-side only. Never commit, never expose to the client.
CLERK_SECRET_KEY=
